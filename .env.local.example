# ─── Solana Network ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# ─── Drift Vault ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAULT_PROGRAM_ID=dRiftyHA39MWEi3m9aunc5MzRF1JYuBsbn6VPcn33UH
DRIFT_ENV=mainnet-beta

# ─── AI Agent ────────────────────────────────────────────────────────────────
# Ed25519 keypair for signing rebalance instructions (server-side only, NEVER expose to client)
AGENT_PRIVATE_KEY=your_base58_encoded_private_key_here

# Rebalance threshold: minimum funding spread improvement to trigger a rebalance (1% = 0.01)
MIN_SPREAD_IMPROVEMENT=0.01

# Health rate floor: vault refuses to operate below this level
HEALTH_RATE_FLOOR=1.05

# Delta drift threshold: rebalance if delta deviates more than this from zero
DELTA_DRIFT_THRESHOLD=0.02

# Cron interval in milliseconds (900000 = 15 minutes)
REBALANCE_INTERVAL_MS=900000

# ─── Optional: Vercel KV for persistent agent logs ───────────────────────────
# KV_URL=your_vercel_kv_url
# KV_REST_API_URL=your_kv_rest_api_url
# KV_REST_API_TOKEN=your_kv_token
